  m_text: "\u25CF <b>Collect: </b>Drag blocks into your tray one by one.\\n\u25CF
    <b>Count: </b>You need exactly 10 of the same item to make a trade.\\n\u25CF
    <b>Trade:</b> Drag your group of 10 to the Banker.\\n\u25CF 10 Ones cube \u2192
    Get 1 Ten rod\\n\u25CF 10 Tens rod \u2192 Get 1 Hundred flat square\\n\u25CF
    <b>Warning:</b> The Banker is strict! If you try to trade 9 or 11, the trade
    will fail.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9ecce5ba5d2bf1543895d404d7a36c8c, type: 2}
